{
  "name": "ui-frontend",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^24.0.0",
    "npm": "^12.0.0"
  },
  "scripts": {
    "dev": "tsx ./server.ts --local-dev",
    "start": "node dist/server.js",
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "npm run lint:eslint && npm run lint:package-json",
    "lint:eslint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint:eslint:fix": "eslint ./src --fix",
    "lint:package-json": "npmPkgJsonLint .",
    "preview": "vite preview",
    "test:vi": "vitest",
    "test:cy": "cypress run --component --browser chrome",
    "test:cy:open": "cypress open --component --browser chrome",
    "generate-graphql-types": "sh scripts/generate-graphql-types.sh",
    "generate-graphql-types:watch": "sh scripts/generate-graphql-types-watch.sh",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "4.2.6",
    "@fastify/autoload": "6.4.0",
    "@fastify/cookie": "11.1.1",
    "@fastify/cors": "11.3.0",
    "@fastify/env": "7.0.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/http-proxy": "11.5.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/secure-session": "8.3.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/session": "11.1.1",
    "@fastify/static": "10.1.0",
    "@fastify/vite": "9.1.1",
    "@hookform/resolvers": "5.4.0",
    "@monaco-editor/react": "4.7.0",
    "@openapi-contrib/openapi-schema-to-json-schema": "5.1.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.220.0",
    "@opentelemetry/instrumentation": "0.220.0",
    "@opentelemetry/instrumentation-fastify": "0.57.0",
    "@opentelemetry/instrumentation-undici": "0.30.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@sentry/node": "10.65.0",
    "@sentry/react": "10.65.0",
    "@sentry/vite-plugin": "5.4.0",
    "@ui5/webcomponents": "2.24.0",
    "@ui5/webcomponents-fiori": "2.24.0",
    "@ui5/webcomponents-icons": "2.24.0",
    "@ui5/webcomponents-react": "2.24.1",
    "@ui5/webcomponents-react-charts": "2.24.1",
    "@xyflow/react": "12.11.2",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "elkjs": "0.11.1",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "graphql": "16.14.2",
    "graphql-config": "5.1.6",
    "graphql-sse": "2.6.0",
    "i18next": "26.3.6",
    "javascript-time-ago": "2.6.4",
    "js-yaml": "4.3.0",
    "monaco-editor": "0.55.1",
    "monaco-yaml": "5.5.1",
    "path-browserify": "1.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-i18next": "17.0.9",
    "react-router-dom": "7.18.1",
    "react-time-ago": "7.4.4",
    "swr": "2.4.2",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.5",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/client-preset": "6.1.0",
    "@testing-library/react": "16.3.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@ui5/webcomponents-cypress-commands": "2.24.1",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/eslint-plugin": "1.6.23",
    "cypress": "15.18.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-i18next": "6.1.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "fastify-tsconfig": "3.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "npm-package-json-lint": "10.4.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-plugin-static-copy": "4.1.1",
    "vitest": "4.1.10"
  },
  "npmpackagejsonlint": {
    "rules": {
      "prefer-absolute-version-dependencies": "error",
      "prefer-absolute-version-devDependencies": "error"
    }
  }
}
