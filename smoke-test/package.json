{
  "name": "openmcp-smoke-test",
  "version": "0.1.0",
  "description": "Portable smoke test container for openmcp-project UI deployments",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "scripts": {
    "smoke": "cypress run --config-file cypress.config.ts --headless",
    "smoke:open": "cypress open --config-file cypress.config.ts",
    "smoke:docker:build": "docker build -t openmcp-smoke-test:local .",
    "smoke:docker:run": "docker run --rm -v \"$(pwd)/results:/results\" --env-file .env.smoke openmcp-smoke-test:local",
    "write-results": "node write-results.mjs"
  },
  "devDependencies": {
    "cypress": "15.16.0",
    "typescript": "5.9.3"
  }
}
