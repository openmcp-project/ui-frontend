# Copy this to .env.smoke and fill in your values.
# NEVER commit .env.smoke (it is gitignored).

# Required
CYPRESS_BASE_URL=https://my-ui.example.com
SMOKE_USERNAME=my-user@example.com
SMOKE_PASSWORD=changeme

# Optional: client certificate paths (inside container when using -v)
# CYPRESS_CLIENT_CERT_PATH=/certs/client.crt
# CYPRESS_CLIENT_KEY_PATH=/certs/client.key

# Resource names (cleaned up before run unless SMOKE_SKIP_CLEANUP=true)
SMOKE_PROJECT_NAME=smoke-test-project
SMOKE_WORKSPACE_NAME=smoke-test-ws
SMOKE_MCP_NAME=smoke-test-mcp
SMOKE_SKIP_CLEANUP=false

# Optional: comma-separated emails to add as admins on project, workspace, and
# control plane — useful for ops/debugging access after the smoke test run
# SMOKE_EXTRA_ADMINS=alice@example.com,bob@example.com

# Optional: apply SmokeTestResult CRD to cluster after run
# KUBECONFIG=/root/.kube/config
# SMOKE_RESULT_NAMESPACE=smoke-tests   # namespace to write results into (default: smoke-tests)
